{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Run DemoApplication",
            "request": "launch",
            "mainClass": "com.training.demo.DemoApplication",
            "projectName": "demo",
            "cwd": "${workspaceFolder}/demo",
            "preLaunchTask": "Maven: Compile demo"
        },
        {
            "type": "java",
            "name": "Run DemoApplication (no pre-task)",
            "request": "launch",
            "mainClass": "com.training.demo.DemoApplication",
            "projectName": "demo",
            "cwd": "${workspaceFolder}/demo"
        },
        {
            "type": "java",
            "name": "Debug Current Java File",
            "request": "launch",
            "mainClass": "${file}"
        }
    ]
}