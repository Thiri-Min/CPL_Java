{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Maven: Compile demo",
            "type": "shell",
            "command": ".\\mvnw.cmd",
            "args": ["compile", "-DskipTests"],
            "options": {
                "cwd": "${workspaceFolder}/demo"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Maven: Spring Boot Run",
            "type": "shell",
            "command": ".\\mvnw.cmd",
            "args": ["spring-boot:run"],
            "options": {
                "cwd": "${workspaceFolder}/demo"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Maven: Clean Package",
            "type": "shell",
            "command": ".\\mvnw.cmd",
            "args": ["clean", "package"],
            "options": {
                "cwd": "${workspaceFolder}/demo"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Maven: Test",
            "type": "shell",
            "command": ".\\mvnw.cmd",
            "args": ["test"],
            "options": {
                "cwd": "${workspaceFolder}/demo"
            },
            "group": "test",
            "problemMatcher": []
        }
    ]
}
